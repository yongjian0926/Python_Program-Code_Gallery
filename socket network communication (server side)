#演示Socket服务端开发
import socket
#创建Socket对象
socket_server = socket.socket()

#绑定IP地址和端口
socket_server.bind(("0.0.0.0",8888))

#监听接口
socket_server.listen(1)   #整数值：允许链接的数量

#等待客户端链接
#result:tuple=socket_server.accept()
#conn=result[0]      #客户端和服务器的链接对象
#address=result[1]   #客户端的地址信息
conn, address=socket_server.accept()
#accept返回的是二维元组（链接对象，客户端地址信息）
#可以通过 变量1，变量2=socket_server.accept()的形式直接接受二元元组的两个元素
#accept()方法，是阻塞方法

print(f"接受到了客户端的连接，客户端的信息是：{address}")

while True:
    #接受客户端消息，要使用客户端与服务端的本次链接对象，而非socket_server对象
    data=conn.recv(1024).decode("UTF-8")
    #recv接受的参数是缓冲区大小，一般给1024即可
    #热词v方法的返回值是一个直接组也就是bytes对象，不是字符申，可以通过decode 方法通过UTF-8编码，将字节数组转换为字符串对象
    print(f"客户端来的消息是：{data}")

    #发送回复消息
    msg = input("请输入你要和客户端回复的消息：")
    if msg=="exit":
        break
    conn.send(msg.encode("UTF-8"))
#关闭链接
conn.close()
socket_server.close()
